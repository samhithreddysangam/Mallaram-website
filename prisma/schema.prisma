datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  password      String
  role          String    @default("FARMER") // ADMIN, FARMER
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  bookings      Booking[]
  complaints    Complaint[]
}

model Slot {
  id            String    @id @default(cuid())
  date          DateTime
  startTime     String
  endTime       String
  capacity      Int       @default(10)
  currentBookings Int     @default(0)
  location      String    @default("IKP Centre Mallaram")
  bookings      Booking[]
  
  @@unique([date, startTime, endTime])
}

model Booking {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  slotId        String
  slot          Slot          @relation(fields: [slotId], references: [id])
  status        String        @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  qrCode        String?       // Reference or data for QR
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model WeatherAlert {
  id            String    @id @default(cuid())
  type          String    // e.g., "RAIN", "STORM"
  severity      String    // e.g., "LOW", "MEDIUM", "HIGH"
  message       String
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
}

model IrrigationSchedule {
  id            String    @id @default(cuid())
  title         String
  description   String?
  startTime     DateTime
  endTime       DateTime
  area          String?   // e.g., "North Canal", "South Fields"
  createdAt     DateTime  @default(now())
}

model CropPrice {
  id            String    @id @default(cuid())
  cropName      String
  price         Float
  unit          String    @default("Quintal")
  district      String    @default("Rajanna Sircilla")
  date          DateTime  @default(now())
  
  @@index([cropName, date])
}

model Complaint {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  subject       String
  description   String
  status        String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  createdAt     DateTime  @default(now())
}

model Scheme {
  id            String    @id @default(cuid())
  title         String
  link          String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model GalleryImage {
  id            String    @id @default(cuid())
  url           String
  alt           String?
  description   String?
  createdAt     DateTime  @default(now())
}

model FundUsage {
  id            String    @id @default(cuid())
  label         String
  amount        Float
  description   String?
  date          DateTime  @default(now())
  category      String?   // e.g., Infrastructure, Education, Healthcare
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VillageMetric {
  id            String    @id @default(cuid())
  label         String    // e.g., "Street Lights", "CCTV Network"
  value         String    // e.g., "142/145", "12 Active"
  status        String    // e.g., "Working Well", "All Safe"
  icon          String    // icon name: Lightbulb, Video, Recycle, Zap, Activity
  color         String    // text color class: text-amber-500
  bg            String    // bg color class: bg-amber-500/10
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model VillagePerformance {
  id            String    @id @default(cuid())
  label         String    // e.g., "Energy Usage"
  value         String    // e.g., "12% Reduction"
  percentage    Int       @default(85) // bar width percentage
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WaterSource {
  id            String    @id @default(cuid())
  label         String    // e.g., "Main Reservoir"
  level         Int       @default(50) // percentage 0-100
  status        String    // e.g., "Stable", "Normal", "Low"
  icon          String    // icon name: Waves, Droplets, Droplet
  order         Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
