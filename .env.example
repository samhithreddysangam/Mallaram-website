=====================================================
# 🚨 CRITICAL: Production Deployment Configuration
# =====================================================
# Read EVERY section below before deploying!
# =====================================================

# ====================================================
# NextAuth v5 Beta — REQUIRED for login to work
# ====================================================

# 1. Generate a strong secret: run `openssl rand -base64 32` in your terminal
#    Paste the output here. This encrypts JWT session tokens.
AUTH_SECRET=

# 2. Set this to your PRODUCTION domain (NOT localhost!)
#    Example: AUTH_URL=https://mallaram.vercel.app
#    ⚠️ If this is wrong, login silently fails & redirects back to login
AUTH_URL=

# (Optional) Set to true if behind a proxy / custom domain
AUTH_TRUST_HOST=true

# ====================================================
# PostgreSQL Database — REQUIRED
# ====================================================

# For Supabase:
# - DATABASE_URL: pooled connection (port 6543) with ?pgbouncer=true
# - DIRECT_URL: direct connection (port 5432) for migrations
# 
# On Vercel/Netlify: paste both strings as environment variables
# On other hosts: ensure your DB allows connections from the server IP

DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"

# ====================================================
# Supabase (Optional — for file uploads / storage)
# ====================================================

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ====================================================
# Deployment Checklist (tick these off before launch)
# ====================================================
# 1. [ ] AUTH_SECRET set to a real secret (run: openssl rand -base64 32)
# 2. [ ] AUTH_URL set to your production domain (e.g., https://mysite.com)
# 3. [ ] DATABASE_URL & DIRECT_URL point to your production DB
# 4. [ ] Database seeded with admin user (run: npx prisma db seed)
# 5. [ ] Visit /api/diagnostic after deploy to verify everything
